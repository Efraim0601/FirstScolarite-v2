{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "FirstPay Studio — Overview",
  "uid": "firstpay-overview",
  "tags": ["firstpay", "slo"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "15s",
  "templating": {
    "list": [
      {
        "name": "application",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_server_requests_seconds_count, application)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Débit HTTP (req/s) par service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=~\"$application\"}[1m])) by (application)",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latence P50 / P99 (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.1 } ] } } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=~\"$application\"}[5m])) by (le, application))",
          "legendFormat": "P50 {{application}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=~\"$application\"}[5m])) by (le, application))",
          "legendFormat": "P99 {{application}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Taux d'erreur 5xx (%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "targets": [
        {
          "expr": "100 * sum(rate(http_server_requests_seconds_count{status=~\"5..\",application=~\"$application\"}[5m])) by (application) / clamp_min(sum(rate(http_server_requests_seconds_count{application=~\"$application\"}[5m])) by (application), 1)",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Heap JVM utilisé (%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "targets": [
        {
          "expr": "100 * sum(jvm_memory_used_bytes{area=\"heap\",application=~\"$application\"}) by (application) / clamp_min(sum(jvm_memory_max_bytes{area=\"heap\",application=~\"$application\"}) by (application), 1)",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "État des circuit breakers",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(resilience4j_circuitbreaker_state{state=\"open\"}) by (name)",
          "legendFormat": "{{name}} (open)"
        }
      ]
    },
    {
      "id": 6,
      "title": "Lag consumer Kafka",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(kafka_consumer_fetch_manager_records_lag{application=~\"$application\"}) by (application)",
          "legendFormat": "{{application}}"
        }
      ]
    }
  ]
}
