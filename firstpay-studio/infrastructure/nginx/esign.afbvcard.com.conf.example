# Exemple de site nginx pour FirstPay Studio derrière Certbot.
# Copier vers /etc/nginx/sites-available/esign.afbvcard.com puis activer :
#   sudo ln -sf /etc/nginx/sites-available/esign.afbvcard.com /etc/nginx/sites-enabled/
#   sudo certbot --nginx -d esign.afbvcard.com
#   sudo nginx -t && sudo systemctl reload nginx
#
# Prérequis Docker (stack production mode nginx) :
#   curl -sf http://127.0.0.1:14200/   → 200
#   curl -sf http://127.0.0.1:18080/actuator/health → 200

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

upstream firstpay_frontend {
    server 127.0.0.1:14200;
    keepalive 16;
}

upstream firstpay_gateway {
    server 127.0.0.1:18080;
    keepalive 16;
}

server {
    listen 80;
    server_name esign.afbvcard.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name esign.afbvcard.com;

    ssl_certificate     /etc/letsencrypt/live/esign.afbvcard.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/esign.afbvcard.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Webhooks TrustPayWay (gateway → payment-service)
    location /webhooks/ {
        proxy_pass http://firstpay_gateway;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }

    # API REST (optionnel : bypass direct vers la gateway)
    location /api/ {
        proxy_pass http://firstpay_gateway;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffering off;
        proxy_read_timeout 300s;
    }

    # Application Angular (le conteneur frontend proxie aussi /api/ si vous n'utilisez que cette location)
    location / {
        proxy_pass http://firstpay_frontend;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        $connection_upgrade;
        proxy_read_timeout 60s;
    }
}
