# Copier vers .env à la racine du projet avant le déploiement :
#   cp .env.production.example .env
#   nano .env

# ── Domaine & SSL ──
# Caddy (REVERSE_PROXY=caddy) : Let's Encrypt automatique via Caddy sur 80/443
# nginx hôte (REVERSE_PROXY=nginx) : Certbot sur le serveur, Docker sur 127.0.0.1:14200
REVERSE_PROXY=nginx
DOMAIN=esign.afbdei.com
SSL_EMAIL=admin@afbdei.com

# ── Secrets (OBLIGATOIRE — générer des valeurs uniques) ──
# openssl rand -base64 48
JWT_SECRET=REMPLACER_PAR_SECRET_JWT_MIN_32_CARACTERES
# openssl rand -base64 32
DB_PASS=REMPLACER_PAR_MOT_DE_PASSE_POSTGRES_FORT
# Token partagé gateway ↔ partner-service (/internal/**)
# openssl rand -base64 32
INTERNAL_TOKEN=REMPLACER_PAR_TOKEN_INTERNE_FORT
DB_USER=firstpay

# ── URLs publiques ──
FRONTEND_ORIGIN=https://esign.afbdei.com
PAYMENT_WEBHOOK_BASE=https://esign.afbdei.com/webhooks/trustpayway

# ── Ports locaux (mode REVERSE_PROXY=nginx, nginx hôte → Docker) ──
NGINX_FRONTEND_PORT=14200
NGINX_GATEWAY_PORT=18080
NGINX_PAYER_PORT=14300

# ── Observabilité (optionnel) ──
TRACING_SAMPLE_RATE=0.05

# ── Reverse proxy (Caddy) ──
# Caddy doit écouter sur 80/443 pour Let's Encrypt (HTTP-01). Si nginx/apache occupe
# ces ports, FREE_PORTS_ON_DEPLOY=true les arrête et les désactive au boot.
# En mode REVERSE_PROXY=nginx, laisser false pour ne pas arrêter nginx.
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
FREE_PORTS_ON_DEPLOY=false

# ── Git (pour update-production.sh) ──
# Branche déployée lors des mises à jour
GIT_BRANCH=master
